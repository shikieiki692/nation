<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:TPM="http://texlive.dante.de/"><rdf:Description about="http://www.miktex.org/packages/wrapfig"><TPM:Name>wrapfig</TPM:Name><TPM:Creator>mpc</TPM:Creator><TPM:Title>Produces figures which text can flow around</TPM:Title><TPM:Version>3.6</TPM:Version><TPM:TargetSystem></TPM:TargetSystem><TPM:Description>Allows figures or tables to have text wrapped around them. Does not work in combination with list environments, but can be used in a parbox or minipage, and in twocolumn format. Supports the float package.</TPM:Description><TPM:RunFiles size="27134">texmf\tex\latex\wrapfig\wrapfig.sty texmf\tpm\packages\wrapfig.tpm</TPM:RunFiles><TPM:TimePackaged>1641762706</TPM:TimePackaged><TPM:MD5>67142f3e96adcf4c06c94db446bb5629</TPM:MD5><TPM:CTAN path="/macros/latex/contrib/wrapfig"/><TPM:License type="lppl"/></rdf:Description></rdf:RDF>